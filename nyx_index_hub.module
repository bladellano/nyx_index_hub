<?php

/**
 * @file
 * Nyx Index Hub module.
 */

use Drupal\Core\Routing\RouteMatchInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityViewDisplayInterface;
use Drupal\Core\Url;

/**
 * Implements hook_help().
 */
function nyx_index_hub_help($route_name, RouteMatchInterface $route_match) {
  switch ($route_name) {
    case 'help.page.nyx_index_hub':
      return '<p>' . t('Module to manage groups, file storages and document indexing.') . '</p>';
  }
}

/**
 * Implements hook_entity_view().
 */
function nyx_index_hub_entity_view(array &$build, EntityInterface $entity, EntityViewDisplayInterface $display, $view_mode) {
  if ($entity->getEntityTypeId() === 'nyx_storage' && $view_mode === 'full') {
    $store_name = $entity->get('store_name')->value;

    if (!empty($store_name)) {
      $build['store_info_button'] = [
        '#type' => 'container',
        '#weight' => 100,
        '#attributes' => ['id' => 'store-info-wrapper'],
      ];

      $build['store_info_button']['button'] = [
        '#type' => 'html_tag',
        '#tag' => 'button',
        '#value' => t('Load Store Information'),
        '#attributes' => [
          'class' => ['button', 'button--primary'],
          'id' => 'load-store-info',
          'data-store-name' => $store_name,
          'onclick' => 'loadStoreInfo(this); return false;',
        ],
      ];

      $build['store_info_button']['result'] = [
        '#type' => 'html_tag',
        '#tag' => 'div',
        '#attributes' => ['id' => 'store-info-result'],
      ];

      $build['store_info_button']['#attached']['library'][] = 'nyx_index_hub/store_info';
    }
  }
}
